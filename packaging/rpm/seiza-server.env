# The packaged server is intentionally loopback-only. Put nginx, Caddy, or a
# load balancer in front of it; see the installed nginx.conf.example.
SEIZA_BIND_ADDR=127.0.0.1:8080
SEIZA_FRONTEND_DIR=/usr/libexec/seiza-server/frontend
# Optional trusted markup inserted before </head> in every frontend document.
# Prefer the file form for multiline analytics or verification tags.
# SEIZA_SITE_HEAD_HTML_FILE=/etc/seiza-server/site-head.html

# systemd StateDirectory=seiza-server owns this path for the dynamic service
# user. The default is a durable SQLx SQLite job store on local disk.
SEIZA_DATA_DIR=/var/lib/seiza-server/data
SEIZA_JOB_BACKEND=sqlx
SEIZA_SQL_DATABASE_URL=sqlite:///var/lib/seiza-server/data/jobs.sqlite3?mode=rwc
SEIZA_QUEUE_TRANSPORT=local
SEIZA_EMBEDDED_WORKERS=true
SEIZA_WORKER_COUNT=1

# Install the prebuilt Seiza datasets here. Canonically named catalogs are
# discovered automatically; explicit paths below override discovery and must
# resolve or the service will reject its configuration at startup.
SEIZA_CATALOG_DIR=/srv/seiza/catalog
# SEIZA_STAR_DATA=/srv/seiza/catalog/stars-deep-gaia17.bin
# SEIZA_BLIND_INDEX=/srv/seiza/catalog/blind-gaia16.idx
# Optional catalog for named-object overlays.
# SEIZA_OBJECT_DATA=/srv/seiza/catalog/objects.bin
# Optional Tycho/Bright Star/GCVS/WDS/IAU identifier sidecar.
# SEIZA_STAR_IDENTIFIER_DATA=/srv/seiza/catalog/stars-lite-tycho2.ids.bin
# Optional reloadable catalogs for time-aware annotations.
# SEIZA_TRANSIENT_DATA=/srv/seiza/catalog/transients.bin
# SEIZA_MINOR_BODY_DATA=/srv/seiza/catalog/minor-bodies.bin

# Uploaded originals and visual previews expire after one day. Job state and
# WCS metadata remain available at their durable solution URLs.
SEIZA_UPLOAD_RETENTION_SECONDS=86400
SEIZA_UPLOAD_CLEANUP_INTERVAL_SECONDS=3600

# Change these when moving object/job storage or workers to AWS.
# SEIZA_STORAGE_BACKEND=s3
# SEIZA_S3_BUCKET=seiza-solves
# SEIZA_QUEUE_TRANSPORT=sqs
# SEIZA_SQS_QUEUE_URL=https://sqs.us-west-2.amazonaws.com/123456789012/seiza-solves
# SEIZA_SQS_PRIORITY_QUEUE_URL=https://sqs.us-west-2.amazonaws.com/123456789012/seiza-solves-priority
# SEIZA_SQS_PRIORITY_WEIGHT=2
# SEIZA_PRIORITY_API_KEYS=load-from-a-protected-environment-file
# SEIZA_JOB_BACKEND=dynamodb
# SEIZA_DYNAMODB_TABLE=seiza-jobs

# Number of reverse proxies that append to X-Forwarded-For. Zero (default)
# ignores forwarded headers and rate-limits sign-in requests by peer address.
# Set to 1 when this host sits behind a single nginx/ALB that appends XFF.
# SEIZA_TRUSTED_PROXY_HOPS=1

# Canonical external origin used by solution Open Graph links. Set this in
# production even in public auth mode; it is also required by accounts mode.
# SEIZA_PUBLIC_BASE_URL=https://solve.example.com

# Account identity storage is independent of the job backend. SQLx defaults to
# SEIZA_SQL_DATABASE_URL; DynamoDB requires the dedicated identity table.
# SEIZA_AUTH_MODE=accounts
# SEIZA_IDENTITY_BACKEND=sqlx
# SEIZA_IDENTITY_SQL_DATABASE_URL=sqlite:///var/lib/seiza-server/data/jobs.sqlite3?mode=rwc
# SEIZA_IDENTITY_DYNAMODB_TABLE=seiza-identity
# SEIZA_AUTH_CODE_PEPPER_FILE=/etc/seiza-server/secrets/auth-code-pepper
# SEIZA_EMAIL_PROVIDER=ses
# SEIZA_EMAIL_FROM=Seiza <solve@example.com>
# SEIZA_SES_FROM_IDENTITY_ARN=arn:aws:ses:us-west-2:123456789012:identity/example.com
# SEIZA_SES_ROLE_ARN=arn:aws:iam::123456789012:role/seiza-email-sender
# SEIZA_SES_ROLE_EXTERNAL_ID_FILE=/etc/seiza-server/secrets/ses-external-id
# For authenticated SMTP instead of SES:
# SEIZA_EMAIL_PROVIDER=smtp
# SEIZA_SMTP_HOST=smtp.example.com
# SEIZA_SMTP_PORT=587
# SEIZA_SMTP_USERNAME=seiza
# SEIZA_SMTP_PASSWORD_FILE=/etc/seiza-server/secrets/smtp-password
# SEIZA_SMTP_TLS=starttls
# SEIZA_SMTP_TIMEOUT_SECONDS=30
