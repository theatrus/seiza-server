# Network and UI
SEIZA_BIND_ADDR=127.0.0.1:8080
SEIZA_FRONTEND_DIR=frontend/dist

# Solver data. Canonically named files in SEIZA_CATALOG_DIR are discovered
# automatically; explicit per-catalog paths override discovery and must resolve.
SEIZA_CATALOG_DIR=/absolute/path/to/seiza-data
# The deep Gaia G<=17 catalog and G<=16 blind index are preferred when present.
# SEIZA_STAR_DATA=/absolute/path/to/stars-deep-gaia17.bin
# SEIZA_BLIND_INDEX=/absolute/path/to/blind-gaia16.idx
# Optional deep-sky/named-star catalog used to label generated overlays.
# SEIZA_OBJECT_DATA=/absolute/path/to/objects.bin
# Optional Tycho/Bright Star/GCVS/WDS/IAU identifier sidecar for searchable
# stellar designations and the independent Star identifiers overlay layer.
# SEIZA_STAR_IDENTIFIER_DATA=/absolute/path/to/stars-lite-tycho2.ids.bin
# Optional hot-reloaded transient and minor-body catalogs. These are needed by
# the API process, not separate solver workers.
# SEIZA_TRANSIENT_DATA=/absolute/path/to/transients.bin
# SEIZA_MINOR_BODY_DATA=/absolute/path/to/minor-bodies.bin

# Predicted satellite tracks are enabled when a solve has one shutter-open
# interval and an observer location. Current CelesTrak data and epoch-matched
# historical data are resolved and cached on demand. Historical lookup tries
# the Seiza rolling mirror before falling back to IAU SatChecker.
SEIZA_SATELLITE_TRACKS=true
# SEIZA_SATELLITE_CACHE_DIR=./data/satellites
# SEIZA_SATELLITE_CACHE_MAX_BYTES=5368709120

# Local development defaults
SEIZA_STORAGE_BACKEND=local
SEIZA_DATA_DIR=./data
# Durable job store. SQLx accepts SQLite for local development and PostgreSQL
# in a multi-host deployment. `SEIZA_QUEUE_DATABASE` remains the convenient
# local file-path default when `SEIZA_SQL_DATABASE_URL` is unset.
SEIZA_JOB_BACKEND=sqlx
SEIZA_QUEUE_DATABASE=./data/jobs.sqlite3
# SEIZA_SQL_DATABASE_URL=sqlite://./data/jobs.sqlite3?mode=rwc
# SEIZA_SQL_DATABASE_URL=postgres://seiza:password@postgres/seiza
SEIZA_QUEUE_TRANSPORT=local
SEIZA_WORKER_COUNT=1
SEIZA_EMBEDDED_WORKERS=true
# Required when separate worker processes use the authenticated worker API.
# SEIZA_WORKER_TOKEN=replace-with-a-long-random-secret
SEIZA_LEASE_SECONDS=900
# Logical file limit. The browser sends each file as retryable 32 MiB chunks.
SEIZA_MAX_UPLOAD_BYTES=104857600
# Originals and on-demand image previews are removed after one day. Durable
# job state, solutions, and downloadable WCS headers are retained.
SEIZA_UPLOAD_RETENTION_SECONDS=86400
SEIZA_UPLOAD_CLEANUP_INTERVAL_SECONDS=3600
SEIZA_RATE_LIMIT_PER_MINUTE=6
SEIZA_RATE_LIMIT_BURST=3
# Number of reverse proxies that append to X-Forwarded-For. Zero (default)
# ignores forwarded headers and rate-limits sign-in requests by peer address.
# Set to 1 behind a single load balancer or nginx that overwrites/appends XFF.
SEIZA_TRUSTED_PROXY_HOPS=0

# `public` accepts anonymous use; `stub-api-key` requires a nonempty key but
# does not validate it. `accounts` enables verified-email browser sessions.
SEIZA_AUTH_MODE=public
# Account mode keeps identity data separate from jobs. SQLx defaults to the job
# database URL; DynamoDB uses the dedicated table template under infra/aws.
# SEIZA_IDENTITY_BACKEND=sqlx
# SEIZA_IDENTITY_SQL_DATABASE_URL=sqlite://data/jobs.sqlite3?mode=rwc
# SEIZA_IDENTITY_DYNAMODB_TABLE=seiza-identity
# Accounts mode also requires a canonical origin, a mounted 32-byte-or-longer
# code pepper, and either Amazon SES or authenticated SMTP email delivery.
# SEIZA_PUBLIC_BASE_URL=https://solve.example.com
# SEIZA_AUTH_CODE_PEPPER_FILE=/run/secrets/seiza-auth-code-pepper
# SEIZA_EMAIL_PROVIDER=ses
# SEIZA_EMAIL_FROM=Seiza <solve@example.com>
# SEIZA_SES_FROM_IDENTITY_ARN=arn:aws:ses:us-west-2:123456789012:identity/example.com
# SEIZA_SES_ROLE_ARN=arn:aws:iam::123456789012:role/seiza-email-sender
# SEIZA_SES_ROLE_EXTERNAL_ID_FILE=/run/secrets/seiza-ses-external-id
# Or use SMTP with required TLS and authentication:
# SEIZA_EMAIL_PROVIDER=smtp
# SEIZA_SMTP_HOST=smtp.example.com
# SEIZA_SMTP_PORT=587
# SEIZA_SMTP_USERNAME=seiza
# SEIZA_SMTP_PASSWORD_FILE=/run/secrets/seiza-smtp-password
# SEIZA_SMTP_TLS=starttls
# SEIZA_SMTP_TIMEOUT_SECONDS=30

# Set these and run `cargo run --features aws` for S3 object storage.
# SEIZA_STORAGE_BACKEND=s3
# SEIZA_S3_BUCKET=seiza-solves
# SEIZA_S3_PREFIX=uploads
# SEIZA_QUEUE_TRANSPORT=sqs
# SEIZA_SQS_QUEUE_URL=https://sqs.us-west-2.amazonaws.com/123456789012/seiza-solves
# Optional weighted priority queue for selected API keys.
# SEIZA_SQS_PRIORITY_QUEUE_URL=https://sqs.us-west-2.amazonaws.com/123456789012/seiza-solves-priority
# SEIZA_SQS_PRIORITY_WEIGHT=4
# SEIZA_PRIORITY_API_KEYS=key-one,key-two

# DynamoDB is an alternative durable job store. The table needs only a string
# partition key named `pk`; see infra/aws/seiza-jobs-dynamodb.yaml.
# SEIZA_JOB_BACKEND=dynamodb
# SEIZA_DYNAMODB_TABLE=seiza-jobs
